{
    "homepage": "https://railmapgen.github.io/rmg-runtime",
    "name": "@railmapgen/rmg-runtime",
    "repository": "github:railmapgen/rmg-runtime",
    "bugs": {
        "url": "https://github.com/railmapgen/rmg-runtime/issues"
    },
    "license": "GPL-3.0-only",
    "type": "module",
    "dependencies": {
        "i18next": "^26.0.8"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^24.12.2",
        "eslint": "^10.2.1",
        "eslint-plugin-prettier": "^5.5.5",
        "global-jsdom": "^29.0.0",
        "jsdom": "^29.0.2",
        "prettier": "^3.8.3",
        "tsdown": "^0.21.10",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0",
        "vite": "^8.0.10"
    },
    "scripts": {
        "dev": "vite --host",
        "build:package": "tsc && tsdown src/index.ts src/util/index.ts",
        "build:docs": "typedoc --tsconfig tsconfig.prod.json",
        "build": "npm run build:package && npm run build:docs",
        "test": "node --experimental-transform-types --test-force-exit --test",
        "lint": "eslint ./src",
        "lint:fix": "eslint ./src --fix"
    },
    "version": "13.0.4",
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs"
        },
        "./util": {
            "import": "./dist/util/index.mjs"
        }
    },
    "files": [
        "dist"
    ]
}
