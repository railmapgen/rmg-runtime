    "version": "13.0.0",
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs"
        },
        "./util": {
            "import": "./dist/util/index.mjs"
