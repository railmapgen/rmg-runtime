{
    "homepage": "https://railmapgen.github.io/rmg-runtime",
    "name": "@railmapgen/rmg-runtime",
    "repository": "github:railmapgen/rmg-runtime",
    "bugs": {
        "url": "https://github.com/railmapgen/rmg-runtime/issues"
    },
    "license": "GPL-3.0-only",
    "dependencies": {
        "i18next": "^25.10.10"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@testing-library/dom": "^10.4.1",
        "@types/node": "^24.12.0",
        "eslint": "^10.1.0",
        "eslint-plugin-prettier": "^5.5.5",
        "jsdom": "^29.0.1",
        "prettier": "^3.8.1",
        "typedoc": "^0.28.18",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.2",
        "unbuild": "^3.6.1",
        "vite": "^8.0.3",
        "vitest": "^4.1.2"
    },
    "scripts": {
        "dev": "vite --host",
        "build:package": "unbuild",
        "build:docs": "typedoc --tsconfig tsconfig.prod.json",
        "build": "npm run build:package && npm run build:docs",
        "test": "vitest",
        "lint": "eslint ./src",
        "lint:fix": "eslint ./src --fix"
